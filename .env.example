# tronctl environment variables
# Copy this file to .env in your working directory.
# tronctl auto-loads .env from the current directory on startup.
# Explicit flags (--node, --ks-dir, etc.) always take precedence.

# gRPC node endpoint (default: grpc.trongrid.io:50051)
# TRONCTL_NODE=grpc.trongrid.io:50051

# Enable TLS for gRPC connection (set to any value to enable)
# TRONCTL_TLS=true

# TronGrid API key for authenticated access
# TRONGRID_APIKEY=your-api-key-here

# Default signer address (base58)
# TRONCTL_SIGNER=TYourSignerAddressHere

# Keystore directory (default: ~/.tronctl/account-keys)
# TRONCTL_KS_DIR=/path/to/keystores

# Debug flags
# TRONCTL_GRPC_DEBUG=true
# TRONCTL_TX_DEBUG=true
# TRONCTL_ALL_DEBUG=true
